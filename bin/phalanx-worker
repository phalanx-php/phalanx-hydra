#!/usr/bin/env php
<?php

declare(strict_types=1);

$options = getopt('', ['autoload:']);
$autoloadPath = $options['autoload'] ?? null;

if ($autoloadPath === null) {
    $candidates = [
        __DIR__ . '/../vendor/autoload.php',
        __DIR__ . '/../../../vendor/autoload.php',
        __DIR__ . '/../../../../../vendor/autoload.php',
    ];

    foreach ($candidates as $candidate) {
        if (file_exists($candidate)) {
            $autoloadPath = $candidate;
            break;
        }
    }
}

if ($autoloadPath === null || !file_exists($autoloadPath)) {
    fwrite(STDERR, "Cannot find autoload.php\n");
    exit(1);
}

require $autoloadPath;

use Phalanx\Hydra\Runtime\WorkerRuntime;

$runtime = new WorkerRuntime(STDIN, STDOUT, STDERR);
$runtime->run();
