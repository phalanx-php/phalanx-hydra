{
    "name": "phalanx-php/hydra",
    "description": "Worker process parallelism for Phalanx",
    "license": "MIT",
    "type": "library",
    "keywords": ["parallel", "worker", "process", "ipc", "openswoole"],
    "authors": [
        {
            "name": "Jonathan Havens",
            "email": "mail@phalanx-php.com"
        }
    ],
    "homepage": "https://github.com/phalanx-php/phalanx-hydra",
    "require": {
        "php": "^8.4",
        "phalanx-php/aegis": "^0.6"
    },
    "autoload": {
        "psr-4": {
            "Phalanx\\Hydra\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Phalanx\\Hydra\\Tests\\": "tests/"
        }
    },
    "bin": [
        "bin/phalanx-worker"
    ],
    "extra": {
        "branch-alias": {
            "dev-main": "0.2.x-dev"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
